# =============================================================================
# File        : .env.example
# Author      : Prakhar Srivastava
# Date        : 2026-06-21
# Description : -> Template for environment variables.
#               -> Copy to `.env` and fill in real values. `.env` is
#                  gitignored; `.env.example` is committed so contributors
#                  know which variables exist.
# =============================================================================

# --- MLflow tracking -----------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=stock-chart-predictor

# --- DVC remote (Google Drive) ------------------------------------------------
# Paste the ID of a Google Drive folder you've created for DVC. The ID is the
# long string after /folders/ in the folder's URL. First `dvc push` triggers
# an OAuth browser flow; credentials cache under ~/.cache/pydrive2fs.
DVC_GDRIVE_FOLDER_ID=

# --- LLM explainer (OpenAI) ---------------------------------------------------
LLM_EXPLAINER_MODEL=gpt-4o-mini
LLM_EXPLAINER_TEMPERATURE=0.2
LLM_EXPLAINER_MAX_TOKENS=200
OPENAI_API_KEY=

# --- API server ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO
API_CORS_ORIGINS=*

# --- UI -----------------------------------------------------------------------
API_BASE_URL=http://localhost:8000

# --- Model artifacts ----------------------------------------------------------
MODEL_CHECKPOINT_PATH=models/best.pt

# --- Logging (loguru) ---------------------------------------------------------
LOG_LEVEL=INFO

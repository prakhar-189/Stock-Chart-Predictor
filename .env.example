# =============================================================================
# File        : .env.example
# Author      : Prakhar Srivastava
# Date        : 2026-06-21
# Description : -> Template for environment variables.
#               -> Copy to `.env` and fill in real values. `.env` is
#                  gitignored; `.env.example` is committed so contributors
#                  know which variables exist.
# =============================================================================

# --- MLflow tracking -----------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=stock-chart-predictor

# --- DVC remote (DagsHub / S3 / GCS) ------------------------------------------
DVC_REMOTE_URL=
DVC_REMOTE_ACCESS_KEY_ID=
DVC_REMOTE_SECRET_ACCESS_KEY=

# --- LLM explainer (LiteLLM) --------------------------------------------------
# Any LiteLLM-supported provider; see https://docs.litellm.ai/docs/providers
LLM_EXPLAINER_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- API server ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO
API_CORS_ORIGINS=*

# --- Model artifacts ----------------------------------------------------------
MODEL_CHECKPOINT_PATH=models/best.pt